MONGODB_URI=mongodb://mongo:27017/bdi-api
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-with-at-least-12-chars

# The local profile uses ephemeral RSA keys. Production must supply PEM keys:
# JWT_PUBLIC_KEY=
# JWT_PRIVATE_KEY=

# Enable this only behind a trusted reverse proxy.
BDI_API_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
